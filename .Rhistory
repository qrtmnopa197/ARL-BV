trials <- trials %>% mutate(unchosen_frac = ifelse(choice == "fA",fB_ix,fA_ix))
final_ls <- read_fsml("final_ls",model_out_dir=model_out_dir)
view(filt_sum(final_ls$sum,"mu"))
final_ls_Bbv <- get_draws("final_ls",vars=c("B_bv_fr_mu"),model_out_dir=model_out_dir)
final_ls_Brew <- get_draws("final_ls",vars=c("B_rew_fr_mu"),model_out_dir=model_out_dir)
trials_fres <- filter(trials,show_fres == 1) # Get trials on which the cue outcome was received
scd_B_bv_fr_mu <- final_ls_Bbv*sd(trials_fres$box_val) # Standardize
scd_B_rew_fr_mu <- final_ls_Brew*sd(trials_fres$out)
get_ci_pd(draws = abs(scd_B_rew_fr_mu) - abs(scd_B_bv_fr_mu))
